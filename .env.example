# Required for intent + scoring (Gemini)
GEMINI_API_KEY=your_key_here
# Optional: default is gemini-2.5-flash (override if needed, e.g. gemini-flash-latest)
# GEMINI_MODEL=gemini-2.5-flash

# Required for hiring/news search + domain lookup for contacts
TAVILY_API_KEY=your_key_here

# Optional: contact enrichment (top 5 orgs)
HUNTER_API_KEY=your_key_here

# Optional: for --send-emails (verified sender domain in SendGrid)
SENDGRID_API_KEY=your_key_here
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name
